# Copy to .env and adjust. The .env file is gitignored — never commit real secrets.

# --- Database ---
POSTGRES_DB=smartdoc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=jdbc:postgresql://db:5432/smartdoc

# --- GenAI service ---
# Inference backend: "openai" (cloud) or "local" (self-hosted Ollama).
GENAI_BACKEND=openai

# Cloud backend (GENAI_BACKEND=openai):
#   Required. Your OpenAI API key — keep it OUT of git.
OPENAI_API_KEY=
#   Cloud model and (optional) OpenAI-compatible endpoint override.
GENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Local backend (GENAI_BACKEND=local) — runs with: docker compose --profile local up
OLLAMA_BASE_URL=http://ollama:11434
GENAI_LOCAL_MODEL=llama3.2:1b

# How the server reaches the GenAI service inside the compose network (internal).
GENAI_BASE_URL=http://genai:8000

# --- Monitoring (Grafana) ---
# Local Grafana admin credentials. Defaults are throwaway dev values — set a real
# password for anything that matters. Never commit the real .env.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin