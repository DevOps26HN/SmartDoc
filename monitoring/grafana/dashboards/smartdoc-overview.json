{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "SmartDoc service overview — request count, latency and error rate for the Spring Boot server and the GenAI service. Reflects real traffic scraped by Prometheus.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
          "expr": "up{job=~\"smartdoc-.*\"}",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ],
      "title": "Services Up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"smartdoc-server\"}[1m]))",
          "legendFormat": "{{ uri }}",
          "refId": "A"
        }
      ],
      "title": "Server — Request Rate (by URI)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"smartdoc-server\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"smartdoc-server\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "title": "Server — Request Latency (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"smartdoc-server\", outcome=~\"SERVER_ERROR|CLIENT_ERROR\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"smartdoc-server\"}[5m])), 0.001)",
          "legendFormat": "error ratio",
          "refId": "A"
        }
      ],
      "title": "Server — Error Rate (4xx+5xx ratio)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
          "expr": "sum by (handler) (rate(http_requests_total{job=\"smartdoc-genai\"}[1m]))",
          "legendFormat": "{{ handler }}",
          "refId": "A"
        }
      ],
      "title": "GenAI — Request Rate (by handler)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"smartdoc-genai\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "GenAI — Request Latency (p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "smartdoc-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"smartdoc-genai\", status=~\"5.*\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"smartdoc-genai\"}[5m])), 0.001)",
          "legendFormat": "error ratio",
          "refId": "A"
        }
      ],
      "title": "GenAI — Error Rate (5xx ratio)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["smartdoc"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SmartDoc Overview",
  "uid": "smartdoc-overview",
  "version": 2
}
